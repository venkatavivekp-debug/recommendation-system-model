{
  "watch": [
    "src/index.js",
    "src/config",
    "src/routes",
    "src/controllers",
    "src/services",
    "src/models",
    "src/middleware",
    "src/utils"
  ],
  "ext": "js",
  "legacyWatch": true,
  "ignore": [
    "runtime-data/**",
    "src/data/**",
    ".data/**",
    "storage/**",
    "logs/**",
    "*.log"
  ]
}
